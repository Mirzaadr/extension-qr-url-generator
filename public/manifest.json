{
  "manifest_version": 3,
  "name": "QR URL Generator",
  "version": "1.0.1",
  "description": "Generate QR code for current page URL",
  "permissions": ["tabs", "activeTab"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Generate QR Code",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "Mirza Andre"
}