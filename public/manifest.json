{
  "manifest_version": 3,
  "name": "QR URL Generator",
  "version": "1.1.0",
  "description": "Generate QR code for current page URL",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "qr-extension@mirzaadr",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Generate QR Code",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "author": "Mirza Andre"
}